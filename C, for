// C언어 for 문 누적합,곱, 최대값, 최소값

// 누적합
// main.c

#define _CRT_SECURE_NO_WARNINGS

#include <stdio.h>

int main(void)
{
	int i;
	int Num;
	int Sum = 0;

	for (i = 0; i < 5; ++i)
	{
		scanf("%d", &Num);
		Sum += Num;
	}
	printf("%d", Sum);

	return 0;
}





//누적곱
// Main.c

#define _CRT_SECURE_NO_WARNINGS

#include <stdio.h>

int main(void)
{   
	int i;
	int Num;
	int Sum = 1;

	for (i = 0; i < 5; ++i)
	{
		scanf("%d", &Num);

		Sum *= Num;
	}
	printf("%d", Sum);

	return 0;
}






//최대값
// Main.c

#define _CRT_SECURE_NO_WARNINGS

#include <stdio.h>
#include <limits.h>

int main(void)
{
	int i;
	int Num;
	int Max = INT_MIN;

	for (i = 1; i < 6; ++i)
	{
		scanf("%d", &Num);

		if (Max < Num)
		{
			Max = Num;
		}
	}
	printf("%d", Max);

	return 0;
}





//최소값
// Main.c

#define _CRT_SECURE_NO_WARNINGS

#include <stdio.h>
#include <limits.h>

int main(void)
{
	int i;
	int Num;
	int Min = INT_MAX;

	for (i = 0; i < 5; ++i)
	{
		scanf("%d", &Num);

		if (Num < Min)
		{
			Min = Num;
		}
	}
	printf("%d", Min);

	return 0;
}
